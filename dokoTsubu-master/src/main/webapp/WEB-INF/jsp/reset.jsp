<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<!DOCTYPE html><html lang="ja"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>パスワード設定 | シフト・有休管理</title><link rel="stylesheet" href="<%=request.getContextPath()%>/assets/app.css?v=20260626-2"></head>
<body class="auth-page"><a class="skip-link" href="#main-content">本文へ移動</a><main class="auth-shell" id="main-content" tabindex="-1"><section class="auth-brand"><span class="brand-mark" aria-hidden="true"><svg class="brand-icon" viewBox="0 0 24 24" focusable="false"><rect x="4" y="5" width="16" height="15" rx="2"></rect><path d="M8 3v4M16 3v4M4 10h16M8 15l2.4 2.4L16 12"></path></svg></span><div><strong>シフト・有休管理</strong></div></section><section class="auth-panel"><p class="eyebrow">SECURE ACCOUNT</p><h1>新しいパスワード</h1>
<%if(Boolean.TRUE.equals(request.getAttribute("complete"))){%><div class="alert">パスワードを設定しました。</div><p><a class="button primary" href="<%=request.getContextPath()%>/index.jsp">ログインする</a></p><%}else if(Boolean.FALSE.equals(request.getAttribute("tokenValid"))){%><div class="alert danger">リンクが無効または期限切れです。</div><p><a href="<%=request.getContextPath()%>/forgot">再設定をやり直す</a></p><%}else{%><%if(request.getAttribute("error")!=null){%><div class="alert danger"><%=util.HtmlEscaper.escape(request.getAttribute("error"))%></div><%}%><form method="post" class="stack-form"><input type="hidden" name="token" value="<%=util.HtmlEscaper.escape(request.getParameter("token"))%>"><label>新しいパスワード<input type="password" name="password" minlength="10" required></label><button class="primary wide">パスワードを設定</button></form><%}%>
</section></main></body></html>
